---
import Base from './Base.astro';
import { withBase } from '../config';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  kind?: string;
}
const { title, description, date, kind = 'essay' } = Astro.props;
const dateLabel = date
  .toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })
  .toLowerCase();
---
<Base title={title} description={description}>
  <article class="wrap article">
    <a class="backlink" href={withBase('/writing')}>← writing</a>
    <p class="eyebrow" style="margin-top:1.1rem">{kind} · {dateLabel}</p>
    <h1>{title}</h1>
    <p class="lede">{description}</p>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
