---
<button class="toggle" id="theme-toggle" type="button" aria-label="Toggle colour theme">
  <span class="state state-dark" aria-hidden="false" style="margin-left: 6px;">☾ dark</span>
  <span class="state state-light" aria-hidden="true">☀ light</span>
</button>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle');

  function sync() {
    const dark = root.dataset.theme !== 'light';
    if (btn) {
      btn.setAttribute('aria-pressed', String(!dark));
      btn.querySelector('.state-dark')?.setAttribute('aria-hidden', String(!dark));
      btn.querySelector('.state-light')?.setAttribute('aria-hidden', String(dark));
    }
  }
  sync();

  btn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch (e) {}
    sync();
  });
</script>
