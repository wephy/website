---
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../config';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Writing" description="Essays and notes by Joseph Webb.">
  <section class="wrap pagehead">
    <p class="eyebrow">// {posts.length} {posts.length === 1 ? 'entry' : 'entries'}</p>
    <h1>Writing</h1>
    <div class="list" style="margin-top: 2rem;">
      {posts.map((post) => (
        <a class="item" href={withBase(`/writing/${post.id}`)}>
          <span class="date"><FormattedDate date={post.data.date} /></span>
          <span class="t">{post.data.title}</span>
          <span class="arrow">→</span>
          <span class="d">{post.data.description}</span>
        </a>
      ))}
    </div>
  </section>
</Base>
