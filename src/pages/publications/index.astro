---
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../config';

const papers = (await getCollection('publications', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Publications" description="Publications by Joseph Webb.">
  <section class="wrap pagehead">
    <p class="eyebrow">// {papers.length} {papers.length === 1 ? 'entry' : 'entries'}</p>
    <h1>Publications</h1>
    <div class="list" style="margin-top: 2rem;">
      {papers.map((paper) => (
        <a
          class="item"
          href={paper.data.url}
          target="_blank"
          rel="noopener"
        >
          <span class="date">
            <FormattedDate date={paper.data.date} />
          </span>
          <span class="t">{paper.data.title}</span>
          <span class="arrow ext">↗</span>
          <span class="d">{paper.data.description}</span>
        </a>
      ))}
    </div>
  </section>
</Base>
